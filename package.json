{
  "name": "morphex-api",
  "version": "1.0.0",
  "description": "Universal structured data infrastructure API — any format in, clean JSON out",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "migrate": "prisma migrate dev",
    "studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "seed:system": "node prisma/seed.js",
    "dev:seed": "NODE_ENV=development node scripts/dev-seed.js",
    "verify": "node scripts/verify-env.js",
    "lint": "eslint src --ext .js",
    "generate": "prisma generate",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.42.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.35.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "prisma": "^5.22.0",
    "stripe": "^17.4.0",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "eslint": "^9.15.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
