# ─────────────────────────────────────────────
#  Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development        # development | production | test

# ─────────────────────────────────────────────
#  Database (Prisma / PostgreSQL)
#  Use a pooled connection URL for DATABASE_URL
#  and a direct (non-pooled) URL for DIRECT_URL
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/morphex?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/morphex?schema=public"

# ─────────────────────────────────────────────
#  Redis  (BullMQ queues & rate-limit store)
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
#  Anthropic / Claude
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─────────────────────────────────────────────
#  Auth
# ─────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# ─────────────────────────────────────────────
#  Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────────
#  CORS / Frontend
# ─────────────────────────────────────────────
FRONTEND_URL="http://localhost:3001"

# ─────────────────────────────────────────────
#  Sentry  (leave blank to disable)
# ─────────────────────────────────────────────
SENTRY_DSN=""
